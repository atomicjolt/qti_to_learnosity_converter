      <item ident="ifillblanks_wordbank" title="Fill Blanks Word Bank">
        <itemmetadata>
          <qtimetadata>
            <qtimetadatafield>
              <fieldlabel>question_type</fieldlabel>
              <fieldentry>fill_in_multiple_blanks_question</fieldentry>
            </qtimetadatafield>
            <qtimetadatafield>
              <fieldlabel>points_possible</fieldlabel>
              <fieldentry>2.0</fieldentry>
            </qtimetadatafield>
          </qtimetadata>
        </itemmetadata>
        <presentation>
          <material>
            <mattext texttype="text/html">&lt;p&gt;The [color] car is [speed]&lt;/p&gt;</mattext>
          </material>
          <response_lid ident="response_color">
            <material>
              <mattext>color</mattext>
            </material>
            <render_choice>
              <response_label answer_type="wordbank" ident="word-1">
                <material>
                  <mattext texttype="text/plain">red</mattext>
                </material>
              </response_label>
              <response_label answer_type="wordbank" ident="word-2">
                <material>
                  <mattext texttype="text/plain">blue</mattext>
                </material>
              </response_label>
              <response_label answer_type="wordbank" ident="word-3">
                <material>
                  <mattext texttype="text/plain">fast</mattext>
                </material>
              </response_label>
              <response_label answer_type="wordbank" ident="word-4">
                <material>
                  <mattext texttype="text/plain">slow</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
          <response_lid ident="response_speed">
            <material>
              <mattext>speed</mattext>
            </material>
            <render_choice>
              <response_label answer_type="wordbank" ident="word-1">
                <material>
                  <mattext texttype="text/plain">red</mattext>
                </material>
              </response_label>
              <response_label answer_type="wordbank" ident="word-2">
                <material>
                  <mattext texttype="text/plain">blue</mattext>
                </material>
              </response_label>
              <response_label answer_type="wordbank" ident="word-3">
                <material>
                  <mattext texttype="text/plain">fast</mattext>
                </material>
              </response_label>
              <response_label answer_type="wordbank" ident="word-4">
                <material>
                  <mattext texttype="text/plain">slow</mattext>
                </material>
              </response_label>
            </render_choice>
          </response_lid>
        </presentation>
        <resprocessing>
          <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
          </outcomes>
          <respcondition>
            <conditionvar>
              <varequal respident="response_color">word-1</varequal>
            </conditionvar>
            <setvar varname="SCORE" action="Add">50.00</setvar>
          </respcondition>
          <respcondition>
            <conditionvar>
              <varequal respident="response_speed">word-3</varequal>
            </conditionvar>
            <setvar varname="SCORE" action="Add">50.00</setvar>
          </respcondition>
        </resprocessing>
      </item>
